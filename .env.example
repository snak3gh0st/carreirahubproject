POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# Pipedrive
PIPEDRIVE_API_TOKEN=""
PIPEDRIVE_COMPANY_DOMAIN=""
PIPEDRIVE_WEBHOOK_SECRET=""

# Quickbooks
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_REDIRECT_URI="https://your-domain.com/api/quickbooks/oauth/callback"
QUICKBOOKS_ACCESS_TOKEN=""
QUICKBOOKS_REFRESH_TOKEN=""
QUICKBOOKS_COMPANY_ID=""
QUICKBOOKS_ENVIRONMENT="sandbox"  # or "production"

# DocuSign Integration
DOCUSIGN_INTEGRATION_KEY=           # DocuSign app integration key (Admin -> Apps)
DOCUSIGN_USER_ID=                   # DocuSign user GUID (Admin -> Users)
DOCUSIGN_ACCOUNT_ID=                # DocuSign account ID (Admin -> Account)
DOCUSIGN_BASE_URL=https://demo.docusign.net  # Use https://na4.docusign.net for production
DOCUSIGN_PRIVATE_KEY=               # RSA private key for JWT auth (base64 encoded or multi-line)
DOCUSIGN_WEBHOOK_SECRET=            # HMAC secret for webhook verification (set in DocuSign Connect)

# DocuSign Template (OPTIONAL - falls back to inline PDF if not set)
# Create template in DocuSign UI with merge fields: customer_name, customer_email,
# invoice_number, amount, due_date, service_description
# Template must have role "Client" defined
DOCUSIGN_TEMPLATE_ID=               # Template ID from DocuSign (Templates -> Your Template -> ID in URL)

# Document Storage (DocuSign PDFs + Hub file uploads)
# Zero-cost self-hosted option:
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/app/storage

# AWS S3 option:
# Use this later only if you want managed object storage instead of local disk.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                  # IAM access key with S3 permissions
AWS_SECRET_ACCESS_KEY=              # IAM secret key
S3_BUCKET_NAME=carreirausa-contracts  # S3 bucket name (must exist)

# Bucket requirements:
# - Block all public access: YES
# - Default encryption: AES-256
# - Versioning: Enabled (recommended)
# - IAM policy needs: s3:PutObject, s3:GetObject, s3:HeadObject

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""
TWILIO_PHONE_NUMBER=""  # Outbound voice calls

# Digisac (WhatsApp operacional)
# DIGISAC_API_BASE_URL normalmente termina em /api/v1, ex: https://suaempresa.digisac.me/api/v1
DIGISAC_API_BASE_URL=""
DIGISAC_API_TOKEN=""
DIGISAC_SERVICE_ID=""
DIGISAC_WEBHOOK_SECRET=""          # Configure este mesmo secret no webhook da Digisac
DIGISAC_WORKSPACE_URL=""           # Opcional: ex https://suaempresa.digisac.me para abrir contato em nova aba
DIGISAC_DEFAULT_COUNTRY_CODE="55"  # Usado quando o telefone do aluno nao tem DDI

# Webhook URL pra cadastrar no painel Digisac (Configurações → Webhooks → Criar webhook):
# Digisac NÃO envia secret no header — autenticação é via query param ?secret= na URL.
# Append ?secret=<DIGISAC_WEBHOOK_SECRET> ao final da URL ao cadastrar:
#   Local (ngrok):  https://<id>.ngrok.app/api/webhooks/digisac?secret=<DIGISAC_WEBHOOK_SECRET>
#   Vercel preview: https://<branch>-<project>.vercel.app/api/webhooks/digisac?secret=<DIGISAC_WEBHOOK_SECRET>
#   Vercel prod:    https://carreirausa.sigmaintel.io/api/webhooks/digisac?secret=<DIGISAC_WEBHOOK_SECRET>
#   Swarm prod:     https://app.carreirausa.com/api/webhooks/digisac?secret=<DIGISAC_WEBHOOK_SECRET>
# Eventos a subscrever: message.created (essencial), message.updated (opcional).
# Headers Authorization Bearer / x-digisac-secret / x-webhook-secret / x-api-key continuam
# aceitos pra testes manuais (curl), mas Digisac não os envia automaticamente.

# AI Service
OPENAI_API_KEY=""
# Optional: separate OpenAI project key dedicated to the live oral test.
# This key stays server-side. Browser clients receive only OpenAI ephemeral session credentials.
OPENAI_REALTIME_API_KEY=""
# Optional routing when using a legacy user API key or a specific OpenAI project.
# Project IDs are shown in OpenAI Platform project settings.
OPENAI_ORGANIZATION_ID=""
OPENAI_PROJECT_ID=""
AI_MODEL="gpt-4-turbo-preview"
AI_TEMPERATURE="0.7"
OPENAI_REALTIME_ENGLISH_TEST_MODEL="gpt-realtime-2"
OPENAI_REALTIME_MOCK_INTERVIEW_MODEL="gpt-realtime-2"
OPENAI_REALTIME_INCLUDE_LEGACY_FALLBACK=false
# Internal Sigma-only cost estimates for realtime oral tests. These values are not shown to students or Carreira USA users.
OPENAI_REALTIME_TEXT_INPUT_USD_PER_1M=4
OPENAI_REALTIME_CACHED_TEXT_INPUT_USD_PER_1M=0.4
OPENAI_REALTIME_AUDIO_INPUT_USD_PER_1M=32
OPENAI_REALTIME_TEXT_OUTPUT_USD_PER_1M=24
OPENAI_REALTIME_AUDIO_OUTPUT_USD_PER_1M=64
OPENAI_VOICE_ENGLISH_TEST_MODEL="gpt-5.2-chat-latest"
AI_MODEL_INPUT_USD_PER_1M=1.75
AI_MODEL_OUTPUT_USD_PER_1M=14

# SDR Configuration
SDR_QUALIFICATION_THRESHOLD="70"

# NextAuth
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32
NEXTAUTH_URL="https://your-domain.com"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# Resend (Email Service)
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""   # Resend Dashboard → Webhooks → Signing Secret
EMAIL_FROM="noreply@your-domain.com"
EMAIL_FINANCE_TEAM="finance@your-domain.com"
EMAIL_SUPPORT_TEAM="support@your-domain.com"

# App URL
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Cron Job Secret (for securing cron endpoints)
CRON_SECRET=""

# ===========================================
# Collection Calls (Twilio Voice + OpenAI Realtime SIP)
# ===========================================
# Provider is intentionally direct Twilio + OpenAI Realtime.
COLLECTION_CALL_PROVIDER="twilio_openai_realtime"
COLLECTION_CALL_PUBLIC_BASE_URL="https://your-domain.com"
COLLECTION_CALL_OPENAI_REALTIME_MODEL="gpt-realtime-2"
COLLECTION_CALL_OPENAI_VOICE="marin"

# ===========================================
# ElevenLabs (Alternative Voice AI)
# ===========================================
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""  # Portuguese voice ID

# ===========================================
# Collection Call Configuration
# ===========================================
COLLECTION_CALL_AUTO_DAYS="3"       # Days overdue before auto-call
COLLECTION_CALL_MAX_ATTEMPTS="3"    # Max call attempts per invoice
COLLECTION_CALL_HOURS_START="9"     # Earliest hour to call (local time)
COLLECTION_CALL_HOURS_END="18"      # Latest hour to call (local time)

# ===========================================
# AI Copilot (Phase 19)
# ===========================================
AI_COPILOT_ENABLED=false           # Kill switch — set to true to enable; false = 503 on all /api/dashboard/ai/* routes
AI_RATE_LIMIT_PER_HOUR=50          # Per-user rolling-window message cap (increase cautiously — cost scales linearly)
AI_MODEL_DEFAULT=gpt-5-mini        # Legacy fallback only. Prefer AI_GATEWAY_MODEL_* below.
AI_GATEWAY_MODEL_DASHBOARD_COPILOT=gpt-5-mini
AI_GATEWAY_MODEL_PERSONA_ANALYSIS=gpt-5.2-chat-latest
AI_GATEWAY_MODEL_COLLECTION_CALL_ANALYSIS=gpt-5-nano
AI_GATEWAY_MODEL_CRITICAL_REPORT=gpt-5.2-chat-latest
AI_GATEWAY_MODEL_GENERAL_CHAT=gpt-5-mini
NEXT_PUBLIC_AI_COPILOT_VISIBLE=true # Hide UI bubble without disabling backend (for testing deployment without exposing to users)

# AI Personas — one-click executive analysis per hub
AI_PERSONAS_ENABLED=false          # Gate — when false, chat route ignores personaSlug and UI hides persona card/chip
# Mirror of AI_PERSONAS_ENABLED exposed to the browser (must match server value)
NEXT_PUBLIC_AI_PERSONAS_ENABLED=false

# Slack (Bot Token)
SLACK_BOT_TOKEN=                     # xoxb-... from Slack App → OAuth & Permissions
SLACK_CHANNEL_COMMERCIAL=            # Channel ID (C0...) for #commercial — right-click channel → Copy link
SLACK_CHANNEL_BASTAO=                # Channel ID for #passagem-de-bastao
SLACK_CHANNEL_ENGLISH_TEST=          # Channel ID for #english-test

# Clint Webhook
CLINT_WEBHOOK_SECRET=                # Signing secret from Clint webhook settings
DOCUSIGN_TEMPLATE_EARLY_CAREER=16b5bf7e-7b24-45fd-a853-6a87ddb9079b

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
