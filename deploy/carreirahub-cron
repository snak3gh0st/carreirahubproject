SHELL=/bin/bash
# CarreiraHub cron jobs — reference/fallback only.
# Active setup uses systemd timers (/etc/systemd/system/carreirahub-cron@*.timer)
# with /usr/local/bin/carreirahub-cron wrapper. See deploy/README for details.
#
# If re-installing as crontab: DO NOT use `source .env` — the .env has a
# multi-line RSA key that breaks bash source. Use grep to extract vars.

# Every 5 min
*/5 * * * * root bash -c 'CRON_SECRET=$(grep -m1 '^CRON_SECRET=' /opt/carreirahub/.env | cut -d= -f2-) && curl -sf -m 300 -H "Authorization: Bearer $CRON_SECRET" https://app.carreirausa.com/api/cron/process-queue' >> /var/log/carreirahub-cron.log 2>&1

# Every hour
0 * * * * root bash -c 'CRON_SECRET=$(grep -m1 '^CRON_SECRET=' /opt/carreirahub/.env | cut -d= -f2-) && curl -sf -m 300 -H "Authorization: Bearer $CRON_SECRET" https://app.carreirausa.com/api/cron/evaluate-alerts' >> /var/log/carreirahub-cron.log 2>&1

