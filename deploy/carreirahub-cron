SHELL=/bin/bash
# CarreiraHub cron jobs — mirrors vercel.json crons
# Install: sudo cp carreirahub-cron /etc/cron.d/carreirahub
#          sudo chmod 644 /etc/cron.d/carreirahub
#
# Calls the Next.js API endpoints on the Swarm host.
# CRON_SECRET is read from the .env file at runtime.

# Every 5 min
*/5 * * * * root bash -c 'source /opt/carreirahub/.env && curl -sf -m 300 -H "Authorization: Bearer $CRON_SECRET" https://app.carreirausa.com/api/cron/process-queue' >> /var/log/carreirahub-cron.log 2>&1

# Every hour
0 * * * * root bash -c 'source /opt/carreirahub/.env && curl -sf -m 300 -H "Authorization: Bearer $CRON_SECRET" https://app.carreirausa.com/api/cron/evaluate-alerts' >> /var/log/carreirahub-cron.log 2>&1

# Every 4 hours
0 */4 * * * root bash -c 'source /opt/carreirahub/.env && curl -sf -m 300 -H "Authorization: Bearer $CRON_SECRET" https://app.carreirausa.com/api/cron/monitor-queues' >> /var/log/carreirahub-cron.log 2>&1

# Every 6 hours
0 */6 * * * root bash -c 'source /opt/carreirahub/.env && curl -sf -m 300 -H "Authorization: Bearer $CRON_SECRET" https://app.carreirausa.com/api/cron/overdue-invoice-alerts' >> /var/log/carreirahub-cron.log 2>&1

# Daily 00:30 UTC
30 0 * * * root bash -c 'source /opt/carreirahub/.env && curl -sf -m 300 -H "Authorization: Bearer $CRON_SECRET" https://app.carreirausa.com/api/cron/auto-charge-invoices' >> /var/log/carreirahub-cron.log 2>&1

