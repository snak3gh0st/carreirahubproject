SHELL=/bin/bash
MAILTO=""

# CarreiraHub cron jobs - /etc/cron.d fallback only.
#
# The active production scheduler is systemd:
#   systemctl list-timers 'carreirahub-cron@*'
#
# Install this file only if systemd timers are intentionally disabled:
#   sudo install -m 0644 deploy/carreirahub-cron /etc/cron.d/carreirahub

# Queue processing
*/5 * * * * root /opt/carreirahub/run-cron.sh process-queue >> /var/log/carreirahub-cron.log 2>&1

# Queue and alert monitoring
0 * * * * root /opt/carreirahub/run-cron.sh evaluate-alerts >> /var/log/carreirahub-cron.log 2>&1
0 */4 * * * root /opt/carreirahub/run-cron.sh monitor-queues >> /var/log/carreirahub-cron.log 2>&1
0 */6 * * * root /opt/carreirahub/run-cron.sh overdue-invoice-alerts >> /var/log/carreirahub-cron.log 2>&1

# Billing and QuickBooks
30 0 * * * root /opt/carreirahub/run-cron.sh auto-charge-invoices >> /var/log/carreirahub-cron.log 2>&1
0,45 * * * * root /opt/carreirahub/run-cron.sh refresh-quickbooks-token >> /var/log/carreirahub-cron.log 2>&1
0 2 * * * root /opt/carreirahub/run-cron.sh overdue-invoices >> /var/log/carreirahub-cron.log 2>&1
0 3 * * * root /opt/carreirahub/run-cron.sh clint-sync >> /var/log/carreirahub-cron.log 2>&1
0 9 * * * root /opt/carreirahub/run-cron.sh send-scheduled-invoices >> /var/log/carreirahub-cron.log 2>&1
0 10 * * * root /opt/carreirahub/run-cron.sh invoice-payment-reminder >> /var/log/carreirahub-cron.log 2>&1

# Contracts and collections
0 1 * * * root /opt/carreirahub/run-cron.sh contract-expiration >> /var/log/carreirahub-cron.log 2>&1
0 7 * * * root /opt/carreirahub/run-cron.sh contract-renewal-reminder >> /var/log/carreirahub-cron.log 2>&1
0 13 * * * root /opt/carreirahub/run-cron.sh collection-calls >> /var/log/carreirahub-cron.log 2>&1

# Digests
0 8 * * * root /opt/carreirahub/run-cron.sh cfo-analysis >> /var/log/carreirahub-cron.log 2>&1
0 8 * * * root /opt/carreirahub/run-cron.sh seller-digest >> /var/log/carreirahub-cron.log 2>&1
0 8 * * * root /opt/carreirahub/run-cron.sh finance-digest >> /var/log/carreirahub-cron.log 2>&1
0 8 * * * root /opt/carreirahub/run-cron.sh health-digest >> /var/log/carreirahub-cron.log 2>&1
15 8 * * * root /opt/carreirahub/run-cron.sh ops-daily-digest >> /var/log/carreirahub-cron.log 2>&1
0 8 * * 1 root /opt/carreirahub/run-cron.sh admin-digest >> /var/log/carreirahub-cron.log 2>&1
0 9 * * * root /opt/carreirahub/run-cron.sh daily-ar-digest >> /var/log/carreirahub-cron.log 2>&1
15 9 * * * root /opt/carreirahub/run-cron.sh form-completion-reminder >> /var/log/carreirahub-cron.log 2>&1
0 21 * * * root /opt/carreirahub/run-cron.sh daily-bi-digest >> /var/log/carreirahub-cron.log 2>&1

# Telegram watcher
*/10 * * * * root /opt/carreirahub/cron-watch.sh >> /var/log/carreirahub-watch.log 2>&1
