# CarreiraHub — production env template
# Copy to /opt/carreirahub/.env on the server and fill in all values.
# DO NOT commit the filled file.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXTAUTH_URL=https://app.carreirausa.com
NEXT_PUBLIC_APP_URL=https://app.carreirausa.com
NEXTAUTH_SECRET=

# ── Database (sigmadb) ───────────────────────────────────────────────────────
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ── Redis ────────────────────────────────────────────────────────────────────
# Keep the same external REDIS_URL currently used on Vercel
REDIS_URL=

# ── Cron auth ────────────────────────────────────────────────────────────────
# Used by host cron scheduler (Bearer token) and accepted by all /api/cron/* routes.
# During Vercel overlap also set VERCEL_CRON_SECRET to the same value on Vercel.
CRON_SECRET=

# ── QuickBooks ───────────────────────────────────────────────────────────────
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://app.carreirausa.com/api/quickbooks/oauth/callback
QUICKBOOKS_ENVIRONMENT=production
QUICKBOOKS_REALM_ID=

# ── DocuSign ─────────────────────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
# Multi-line RSA key — base64-encode it: base64 -w0 private.key
# Then decode at runtime: echo "$DOCUSIGN_RSA_PRIVATE_KEY_B64" | base64 -d
DOCUSIGN_RSA_PRIVATE_KEY_B64=
DOCUSIGN_WEBHOOK_SECRET=
DOCUSIGN_TEMPLATE_ID=
DOCUSIGN_BASE_URL=

# ── Resend ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL=

# ── Twilio (WhatsApp) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ── Pipedrive ────────────────────────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_WEBHOOK_SECRET=

# ── Digisac ──────────────────────────────────────────────────────────────────
DIGISAC_API_TOKEN=
DIGISAC_ACCOUNT=
DIGISAC_WEBHOOK_SECRET=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
AI_MODEL=gpt-4-turbo-preview
AI_TEMPERATURE=0.7

# ── SDR ──────────────────────────────────────────────────────────────────────
SDR_QUALIFICATION_THRESHOLD=70
