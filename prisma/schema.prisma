generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                     String              @id @default(uuid())
  email                  String              @unique
  name                   String?
  role                   UserRole            @default(SALES)
  active                 Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  password               String?
  passwordHashedAt       DateTime?
  bulkImports            BulkImport[]        @relation("BulkImports")
  escalatedConversations Conversation[]      @relation("EscalatedConversations")
  sales                  Deal[]
  ownedInvoices          Invoice[]           @relation("InvoiceOwner")
  leadQualifications     LeadQualification[] @relation("LeadQualifications")
  qualifiedLeads         Lead[]              @relation("QualifiedLeads")
  createdLeads           Lead[]              @relation("CreatedLeads")
  createdCustomers       Customer[]          @relation("CreatedCustomers")
  supportTickets         SupportTicket[]     @relation("UserSupportTickets")
  assignedTickets        SupportTicket[]     @relation("AssignedSupportTickets")

  @@index([id])
  @@map("users")
}

model Customer {
  id                   String           @id @default(uuid())
  email                String           @unique
  name                 String
  phone                String?
  pipedrive_id         Int?             @unique
  quickbooks_id        String?          @unique
  stripe_id            String?          @unique
  trello_id            String?          @unique
  cloudtalk_id         String?
  google_contact_id    String?
  metadata             Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  lastPipedriveSyncAt  DateTime?
  lastQuickbooksSyncAt DateTime?
  phoneVerified        Boolean          @default(false)
  preferredLanguage    String?          @default("pt-BR")
  lastQbBalanceSync    DateTime?
  qbBalance            Decimal?         @db.Decimal(10, 2)
  qbTotalInvoiced      Decimal?         @db.Decimal(10, 2)
  qbTotalPaid          Decimal?         @db.Decimal(10, 2)
  docusign_id          String?          @unique
  lastDocusignSyncAt   DateTime?
  address              String?
  city                 String?
  country              String?          @default("USA")
  ssn                  String?
  state                String?
  zipCode              String?
  cpf                  String?
  passport             String?
  dateOfBirth          DateTime?
  createdById          String?
  createdBy            User?            @relation("CreatedCustomers", fields: [createdById], references: [id])
  alerts               Alert[]
  clientUser           ClientUser?
  collectionCalls      CollectionCall[]
  contracts            Contract[]
  deals                Deal[]
  invoices             Invoice[]
  notifications        Notification[]
  payments             Payment[]

  @@index([email])
  @@index([pipedrive_id])
  @@index([createdById])
  @@map("customers")
}

model ClientUser {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  mustResetPw           Boolean   @default(true)
  tempPasswordExpiresAt DateTime?
  resetToken            String?   @unique
  resetTokenExpiresAt   DateTime?
  failedLoginCount      Int       @default(0)
  lockedUntil           DateTime?
  language              String    @default("en")
  lastLoginAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  customerId            String    @unique
  customer              Customer  @relation(fields: [customerId], references: [id])

  @@map("client_users")
}

model Lead {
  id                  String              @id @default(uuid())
  email               String              @unique
  name                String
  phone               String?
  source              LeadSource          @default(WEBSITE)
  status              LeadStatus          @default(NEW)
  pipedrive_person_id Int?                @unique
  qualificationScore  Int?                @default(0)
  qualificationData   Json?
  qualifiedAt         DateTime?
  qualifiedById       String?
  createdById         String?
  convertedToDealId   String?             @unique
  convertedAt         DateTime?
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  conversations       Conversation[]
  qualifications      LeadQualification[]
  convertedToDeal     Deal?               @relation("ConvertedLead", fields: [convertedToDealId], references: [id])
  qualifiedBy         User?               @relation("QualifiedLeads", fields: [qualifiedById], references: [id])
  createdBy           User?               @relation("CreatedLeads", fields: [createdById], references: [id])
  messages            Message[]

  @@index([email])
  @@index([status])
  @@index([pipedrive_person_id])
  @@index([createdById])
  @@map("leads")
}

model Conversation {
  id            String             @id @default(uuid())
  leadId        String
  status        ConversationStatus @default(ACTIVE)
  title         String?
  summary       String?
  escalatedAt   DateTime?
  escalatedToId String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  escalatedTo   User?              @relation("EscalatedConversations", fields: [escalatedToId], references: [id])
  lead          Lead               @relation(fields: [leadId], references: [id])
  messages      Message[]

  @@index([leadId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  leadId         String
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  lead           Lead         @relation(fields: [leadId], references: [id])

  @@index([conversationId])
  @@index([leadId])
  @@map("messages")
}

model LeadQualification {
  id            String   @id @default(uuid())
  leadId        String
  score         Int
  criteria      Json
  qualifiedById String?
  notes         String?
  createdAt     DateTime @default(now())
  lead          Lead     @relation(fields: [leadId], references: [id])
  qualifiedBy   User?    @relation("LeadQualifications", fields: [qualifiedById], references: [id])

  @@index([leadId])
  @@map("lead_qualifications")
}

model Deal {
  id                  String     @id @default(uuid())
  title               String
  value               Decimal    @db.Decimal(10, 2)
  currency            String     @default("USD")
  status              DealStatus @default(OPEN)
  pipedrive_deal_id   Int        @unique
  customerId          String?
  ownerId             String?
  convertedFromLeadId String?    @unique
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  lastPipedriveSyncAt DateTime?
  contractSentAt      DateTime?
  invoiceCreatedAt    DateTime?
  workflowCompletedAt DateTime?
  workflowError       String?
  workflowStartedAt   DateTime?
  workflowStatus      String?
  alerts              Alert[]
  contracts           Contract[]
  customer            Customer?  @relation(fields: [customerId], references: [id])
  owner               User?      @relation(fields: [ownerId], references: [id])
  invoices            Invoice[]
  convertedFromLead   Lead?      @relation("ConvertedLead")

  @@map("deals")
}

model Invoice {
  id                    String           @id @default(uuid())
  invoiceNumber         String?          @unique
  amount                Decimal          @db.Decimal(10, 2)
  dueDate               DateTime
  status                InvoiceStatus    @default(DRAFT)
  quickbooks_invoice_id String?          @unique
  stripe_invoice_id     String?          @unique
  dealId                String?
  customerId            String
  pdfUrl                String?
  installments          Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  amountPaid            Decimal?         @db.Decimal(10, 2)
  contractId            String?          @unique
  lastPaymentReminderAt DateTime?
  paidAt                DateTime?
  paymentMethod         String?
  paymentReminderCount  Int              @default(0)
  stripePaymentIntentId String?          @unique
  stripePaymentLinkId   String?          @unique
  collectionCallCount   Int              @default(0)
  lastCollectionCallAt  DateTime?
  markedOverdueAt       DateTime?
  stripePaymentLinkUrl  String?
  amountRefunded        Decimal?         @default(0) @db.Decimal(10, 2)
  lineItems             Json?
  ownerId               String?
  emailSendAttempts     Int              @default(0)
  emailSentAt           DateTime?
  lastEmailSendError    String?
  autoChargeAttempts    Int               @default(0)
  lastAutoChargeAt      DateTime?
  lastAutoChargeError   String?
  autoChargeStatus      AutoChargeStatus?
  nextAutoChargeRetry   DateTime?
  autoChargePaymentRef  String?
  alerts                Alert[]
  collectionCalls       CollectionCall[]
  contract              Contract?        @relation(fields: [contractId], references: [id])
  customer              Customer         @relation(fields: [customerId], references: [id])
  deal                  Deal?            @relation(fields: [dealId], references: [id])
  owner                 User?            @relation("InvoiceOwner", fields: [ownerId], references: [id])
  notifications         Notification[]
  payments              Payment[]

  @@map("invoices")
}

model Payment {
  id                    String    @id @default(uuid())
  amount                Decimal   @db.Decimal(10, 2)
  currency              String    @default("USD")
  paymentDate           DateTime
  paymentMethod         String?
  referenceNumber       String?
  quickbooks_payment_id String?   @unique
  stripe_payment_id     String?   @unique
  invoiceId             String
  customerId            String
  syncedFromQb          Boolean   @default(false)
  syncedToQb            Boolean   @default(false)
  lastSyncAt            DateTime?
  notes                 String?
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  customer              Customer  @relation(fields: [customerId], references: [id])
  invoice               Invoice   @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([customerId])
  @@index([quickbooks_payment_id])
  @@map("payments")
}

model Contract {
  id                   String         @id @default(uuid())
  docusign_env_id      String?        @unique
  status               ContractStatus @default(DRAFT)
  signedUrl            String?
  dealId               String
  customerId           String
  sentAt               DateTime?
  signedAt             DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  declinedAt           DateTime?
  expiresAt            DateTime?
  invoiceId            String?        @unique
  lastReminderAt       DateTime?
  reminderCount        Int            @default(0)
  signerEmail          String
  signerName           String
  voidedAt             DateTime?
  signedS3Key          String?
  signedS3Url          String?
  signedS3UrlExpiresAt DateTime?
  customer             Customer       @relation(fields: [customerId], references: [id])
  deal                 Deal           @relation(fields: [dealId], references: [id])
  invoice              Invoice?
  notifications        Notification[]

  @@map("contracts")
}

model IntegrationLog {
  id             String   @id @default(uuid())
  service        String
  action         String
  status         String
  payload        Json?
  error          String?
  retryCount     Int      @default(0)
  createdAt      DateTime @default(now())
  durationMs     Int?
  errorCategory  String?
  errorCode      String?
  errorSeverity  String?
  metadata       Json?
  recoveryAction String?

  @@index([status])
  @@index([service])
  @@index([errorCategory])
  @@map("integration_logs")
}

model SystemConfig {
  id                          String    @id @default("system")
  quickbooks_access_token     String?
  quickbooks_refresh_token    String?
  quickbooks_token_expires_at DateTime?
  quickbooks_company_id       String?
  quickbooks_is_authenticated Boolean   @default(false)
  quickbooks_webhook_secret   String?
  pipedrive_webhook_secret    String?
  cron_secret                 String?
  last_qb_sync                DateTime?
  last_pipedrive_sync         DateTime?
  metadata                    Json?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@map("system_config")
}

model Notification {
  id           String             @id @default(uuid())
  type         NotificationType
  status       NotificationStatus @default(PENDING)
  recipient    String
  subject      String
  templateId   String?
  sentAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  invoiceId    String?
  contractId   String?
  customerId   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  contract     Contract?          @relation(fields: [contractId], references: [id])
  customer     Customer?          @relation(fields: [customerId], references: [id])
  invoice      Invoice?           @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([contractId])
  @@index([status])
  @@map("notifications")
}

model BulkImport {
  id               String       @id @default(uuid())
  source           String
  type             String
  status           ImportStatus @default(RUNNING)
  totalRecords     Int          @default(0)
  processedRecords Int          @default(0)
  successCount     Int          @default(0)
  errorCount       Int          @default(0)
  errors           Json?
  startedAt        DateTime     @default(now())
  completedAt      DateTime?
  startedBy        String?
  initiator        User?        @relation("BulkImports", fields: [startedBy], references: [id])

  @@index([status])
  @@index([source])
  @@map("bulk_imports")
}

model QuickBooksItem {
  id          String   @id @default(cuid())
  qbId        String   @unique
  name        String
  description String?
  unitPrice   Decimal? @db.Decimal(10, 2)
  type        String
  active      Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([qbId])
  @@map("quickbooks_items")
}

model QuickBooksPriceLevel {
  id        String   @id @default(uuid())
  qbId      String   @unique
  name      String
  active    Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([qbId])
  @@map("quickbooks_price_levels")
}

model QuickBooksPaymentTerm {
  id              String   @id @default(uuid())
  qbId            String   @unique
  name            String
  dueDays         Int?
  discountDays    Int?
  discountPercent Decimal? @db.Decimal(5, 2)
  active          Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([qbId])
  @@map("quickbooks_payment_terms")
}

model CollectionCall {
  id              String                 @id @default(uuid())
  invoiceId       String
  customerId      String
  phoneNumber     String
  provider        String
  externalCallId  String?
  status          CollectionCallStatus   @default(PENDING)
  duration        Int?
  transcript      String?
  outcome         CollectionCallOutcome?
  paymentPromised Boolean                @default(false)
  promisedDate    DateTime?
  notes           String?
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  initiatedBy     String?
  customer        Customer               @relation(fields: [customerId], references: [id])
  invoice         Invoice                @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([customerId])
  @@index([status])
  @@map("collection_calls")
}

model WebhookEvent {
  id            String    @id @default(cuid())
  service       String
  event_type    String
  event_id      String
  payload       Json
  headers       Json
  status        String
  retry_count   Int       @default(0)
  max_retries   Int       @default(5)
  next_retry_at DateTime?
  last_error    String?
  processed_at  DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([service, event_id])
  @@index([status, next_retry_at])
  @@index([created_at])
  @@map("webhook_events")
}

model CircuitBreakerState {
  id                 String   @id @default(cuid())
  serviceName        String   @unique
  state              String   @default("CLOSED")
  failureCount       Int      @default(0)
  successCount       Int      @default(0)
  lastStateChangeAt  DateTime @default(now())
  lastErrorMessage   String?
  thresholdFailures  Int      @default(5)
  thresholdSuccesses Int      @default(2)
  timeoutMs          Int      @default(60000)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([serviceName])
  @@index([state])
  @@map("circuit_breaker_states")
}

model Alert {
  id             String        @id @default(cuid())
  ruleId         String
  title          String
  description    String
  severity       AlertSeverity @default(MEDIUM)
  status         AlertStatus   @default(ACTIVE)
  invoiceId      String?
  customerId     String?
  dealId         String?
  data           Json?
  triggeredAt    DateTime      @default(now())
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  dismissedAt    DateTime?
  dismissedBy    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  events         AlertEvent[]
  customer       Customer?     @relation(fields: [customerId], references: [id])
  deal           Deal?         @relation(fields: [dealId], references: [id])
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])
  rule           AlertRule     @relation(fields: [ruleId], references: [id])

  @@index([ruleId])
  @@index([status])
  @@index([severity])
  @@index([invoiceId])
  @@index([customerId])
  @@index([dealId])
  @@index([triggeredAt])
  @@map("alerts")
}

model AlertRule {
  id                   String        @id @default(cuid())
  name                 String        @unique
  description          String?
  severity             AlertSeverity @default(MEDIUM)
  condition            String
  evaluationLogic      Json?
  enabled              Boolean       @default(true)
  checkInterval        String        @default("HOURLY")
  lastEvaluatedAt      DateTime?
  maxAlertsPerDay      Int           @default(1)
  autoResolveCondition String?
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  alerts               Alert[]

  @@index([enabled])
  @@index([lastEvaluatedAt])
  @@map("alert_rules")
}

model AlertEvent {
  id             String       @id @default(cuid())
  alertId        String
  eventType      String
  actor          String?
  actorEmail     String?
  reason         String?
  previousStatus AlertStatus?
  newStatus      AlertStatus?
  metadata       Json?
  createdAt      DateTime     @default(now())
  alert          Alert        @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([eventType])
  @@index([createdAt])
  @@map("alert_events")
}

enum UserRole {
  ADMIN
  SALES
  SDR
  FINANCE
  SUPPORT
  OPERATIONAL
  COMMERCIAL
}

enum DealStatus {
  OPEN
  WON
  LOST
  HOLD
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
  PARTIALLY_PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum AutoChargeStatus {
  CHARGED
  RETRY_PENDING
  FAILED
  SKIPPED
}

enum ContractStatus {
  DRAFT
  SENT_FOR_SIGNATURE
  SIGNED
  DECLINED
  EXPIRED
  VIEWED
  VOIDED
}

enum LeadStatus {
  NEW
  QUALIFYING
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  REFERRAL
  SOCIAL_MEDIA
  OTHER
  PIPEDRIVE
}

enum ConversationStatus {
  ACTIVE
  RESOLVED
  ESCALATED
  CLOSED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ImportStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  CONTRACT_SENT
  CONTRACT_REMINDER
  CONTRACT_SIGNED
  CONTRACT_EXPIRED
  PAYMENT_LINK_SENT
  PAYMENT_REMINDER
  PAYMENT_RECEIVED
  HUB_WELCOME
  HUB_INVOICE_AVAILABLE
  HUB_PASSWORD_RESET
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

enum CollectionCallStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  CANCELLED
}

enum CollectionCallOutcome {
  PAYMENT_PROMISED
  PAYMENT_MADE
  DISPUTE
  CALLBACK_REQUESTED
  NO_COMMITMENT
  WRONG_NUMBER
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

model SupportTicket {
  id           String              @id @default(uuid())
  userId       String
  subject      String?
  status       SupportTicketStatus @default(AI_HANDLING)
  priority     SupportPriority     @default(MEDIUM)
  assignedToId String?
  escalatedAt  DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation("UserSupportTickets", fields: [userId], references: [id])
  assignedTo   User?               @relation("AssignedSupportTickets", fields: [assignedToId], references: [id])
  messages     SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([assignedToId])
  @@map("support_tickets")
}

model SupportMessage {
  id        String             @id @default(uuid())
  ticketId  String
  role      SupportMessageRole
  content   String
  metadata  Json?
  createdAt DateTime           @default(now())
  ticket    SupportTicket      @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@map("support_messages")
}

enum SupportTicketStatus {
  AI_HANDLING
  ESCALATED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportMessageRole {
  USER
  AI
  AGENT
}
